# Griot Studio worker environment — African Folktales.
# Copy this file to .env in the worker folder, fill in what you use, then run:
#   npm run now      start immediately and keep rendering as you drop scripts
#   npm run once     process the current batch once and exit
# With no keys, videos still render with motion and music, just no narration.

# ----- Voice: edge-tts, Nigerian English (FREE, no key, recommended) -----
# Microsoft Edge's free neural voices — same Nigerian voices as Azure, but $0.
# Install once:  pip install edge-tts   (see SETUP-VOICE.md)
CF_TTS_PROVIDER=edge
# en-NG-EzinneNeural = Nigerian female storyteller (default).
# en-NG-AbeoNeural   = Nigerian male elder / griot.
CF_EDGE_VOICE=en-NG-EzinneNeural
# Warm, measured storytelling cadence.
CF_EDGE_RATE=-6%
CF_EDGE_PITCH=-2Hz

# ----- Alternative voices (optional, all cost money or need a key) -----
# Microsoft Azure (needs key + card, 500k/mo free): AZURE_SPEECH_KEY=, AZURE_SPEECH_REGION=eastus, CF_TTS_PROVIDER=azure, CF_AZURE_VOICE=en-NG-EzinneNeural
# ElevenLabs (top realism, tiny free tier):        ELEVENLABS_API_KEY=, CF_ELEVEN_VOICE=VR6AewLTigWG4xSOukaG
# Local Piper server (British/US, not Nigerian):   LOCAL_TTS_URL=http://localhost:5111

# ----- Rendering -----
# folktale3d = 3D animated African folktale look (matches the reference character).
CF_STYLE=folktale3d
CF_SCENE_SECONDS=4
CF_INTERVAL=60

# Claude API key powers SEO, character consistency, and scene matching.
ANTHROPIC_API_KEY=
CF_SEO_MODEL=claude-haiku-4-5-20251001

# ----- YouTube auto upload, optional -----
# YT_CLIENT_ID=
# YT_CLIENT_SECRET=
# YT_REFRESH_TOKEN=
# CF_YT_PRIVACY=unlisted
