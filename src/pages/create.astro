    // per clip trimming (video clips)
    function applyTrim(previewAtEnd) {
      const c = clips[selected];
      if (!c || c.type !== "video") return;
      let s = parseFloat(document.getElementById("trimStart").value);
      let e = parseFloat(document.getElementById("trimEnd").value);
      const src = c.srcDur || c.duration;
      s = Math.max(0, Math.min(s, src - 0.5));
      e = Math.min(src, Math.max(e, s + 0.5));
      c.trimStart = s; c.trimEnd = e; c.duration = Math.round((e - s) * 10) / 10;
      document.getElementById("trimStart").value = s;
      document.getElementById("trimEnd").value = e;
      document.getElementById("trimStartVal").textContent = s.toFixed(1) + "s";
      document.getElementById("trimEndVal").textContent = e.toFixed(1) + "s";
      document.getElementById("clipLen").textContent = c.duration.toFixed(1) + "s";
      renderTrack();
      // preview the trimmed frame on the stage
      const base = clipStart(selected);
      const at = previewAtEnd ? base + c.duration - 0.05 : base;
      setPlayhead(at); draw(at);
    }
    document.getElementById("trimStart").addEventListener("input", () => applyTrim(false));
    document.getElementById("trimEnd").addEventListener("input", () => applyTrim(true));

