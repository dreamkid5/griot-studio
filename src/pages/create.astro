    recBtn.addEventListener("click", async () => {
      if (recording) {
        try { mediaRec.stop(); } catch (e) {}
        return;
      }
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
        window.showToast("Recording is not supported in this browser");
        return;
      }
      try {
        recStream = await navigator.mediaDevices.getUserMedia({ audio: true });
      } catch (e) {
        window.showToast("Microphone permission was declined");
        return;
      }
      recChunks = [];
      let rmime = "audio/webm";
      if (!MediaRecorder.isTypeSupported(rmime)) rmime = "";
      mediaRec = rmime ? new MediaRecorder(recStream, { mimeType: rmime }) : new MediaRecorder(recStream);
      mediaRec.ondataavailable = (e) => { if (e.data.size) recChunks.push(e.data); };
      mediaRec.onstop = () => {
        recording = false;
        clearInterval(recTimer);
        recBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0M12 19v3"/></svg> Start recording';
        recBtn.classList.remove("primary");
        recStatus.style.display = "none";
        if (recStream) recStream.getTracks().forEach((t) => t.stop());
        const blob = new Blob(recChunks, { type: "audio/webm" });
        loadVoiceover(URL.createObjectURL(blob), blob, "Voiceover recorded");
      };
      mediaRec.start();
      recording = true;
      recStart = performance.now();
      recBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="2"/></svg> Stop recording';
      recBtn.classList.add("primary");
      recStatus.style.display = "flex";
      document.getElementById("recTime").textContent = "0:00";
      recTimer = setInterval(tickRec, 250);
    });

    async function buildWaveform(file) {
      try {
        const ac = new (window.AudioContext || window.webkitAudioContext)();
        const buf = await ac.decodeAudioData(await file.arrayBuffer());
        const data = buf.getChannelData(0);
        const bars = 130, block = Math.floor(data.length / bars);
        const wave = document.getElementById("wave");
        wave.innerHTML = "";
        for (let b = 0; b < bars; b++) {
          let sum = 0;
          for (let j = 0; j < block; j++) sum += Math.abs(data[b * block + j] || 0);
          const amp = Math.min(1, (sum / block) * 3.2);
          const bar = document.createElement("div");
          bar.className = "b";
          bar.style.height = Math.max(3, amp * 40) + "px";
          wave.appendChild(bar);
        }
        ac.close();
      } catch (e) { /* decoding not supported, keep placeholder */ }
    }

    document.getElementById("autoFit").addEventListener("click", () => {
      if (!clips.length) { window.showToast("Add some clips first"); return; }
