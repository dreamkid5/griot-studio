---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
---
<Layout title="Video Studio" subtitle="Turn images and audio into a finished video" active="create" page="Video Studio">

  <section class="grid vstudio-cols" style="grid-template-columns: minmax(0, 1fr) 340px; gap:18px; align-items:start;">

    <!-- Stage and timeline -->
    <div class="studio-left" style="display:flex; flex-direction:column; gap:16px; min-width:0;">
      <div class="card pad">
        <div class="studio-stage">
          <canvas id="stage" width="1280" height="720"></canvas>
        </div>

        <!-- Transport -->
        <div class="transport">
          <button class="play-btn" id="playBtn" aria-label="Play"><Icon name="play" size={20} /></button>
          <span class="time" id="curTime">0:00</span>
          <div class="scrub" id="scrub"><div class="fill" id="scrubFill"></div></div>
          <span class="time" id="totTime">0:00</span>
        </div>
      </div>

      <!-- Timeline -->
      <div class="timeline">
        <div class="track-label"><Icon name="layers" size={14} />Visual track</div>
        <div class="track" id="clipTrack">
          <button class="clip-add" id="addClipBtn" title="Add image"><Icon name="plus" size={20} /></button>
        </div>

        <div class="track-label" style="margin-top:16px;"><Icon name="music" size={14} />Audio track</div>
        <div class="track audio" id="audioTrack">
          <div class="audio-empty" id="audioEmpty">No audio yet. Add a voiceover or music track to align your clips.</div>
          <div class="wave" id="wave" style="display:none;"></div>
        </div>
      </div>
    </div>

    <!-- Control panel -->
    <div style="display:flex; flex-direction:column; gap:16px; min-width:0;">

      <!-- Add media -->
      <div class="card">
        <div class="card-head"><div><h3>Add media</h3><p>Build your sequence</p></div></div>
        <div class="card-body">
          <button class="btn primary" id="uploadImg" style="width:100%;justify-content:center;margin-bottom:10px;"><Icon name="image" size={16} />Add images</button>
          <button class="btn" id="uploadVideo" style="width:100%;justify-content:center;margin-bottom:10px;"><Icon name="film" size={16} />Add video clips</button>
          <button class="btn" id="uploadAudio" style="width:100%;justify-content:center;"><Icon name="mic" size={16} />Add voiceover</button>
          <p class="hint" style="margin-top:10px;">Mix images and video clips freely. A sample sequence is loaded so you can preview and export right away.</p>
        </div>
      </div>

      <!-- Story builder -->
      <div class="card" style="border-color:var(--violet);box-shadow:inset 0 0 0 1px var(--violet),var(--glow);">
        <div class="card-head"><div><h3>Story builder</h3><p>One script becomes a full video</p></div></div>
        <div class="card-body">
          <div class="field">
            <label>Paste your narration script</label>
            <textarea class="textarea" id="storyScript" style="min-height:110px;" placeholder="Paste your full narration script. Each paragraph or sentence becomes its own illustrated scene."></textarea>
          </div>
          <div class="field" style="margin-bottom:12px;">
            <label>Art style</label>
            <select class="select" id="storyStyle">
              <option value="folktale3d" selected>African folktale (3D animated)</option>
              <option value="watercolor">Watercolor illustration</option>
              <option value="cinematic">Cinematic photo</option>
              <option value="storybook">Storybook painting</option>
              <option value="anime">Anime</option>
              <option value="3d">3D render</option>
              <option value="flat">Flat vector</option>
              <option value="oil">Oil painting</option>
              <option value="pencil">Pencil sketch</option>
              <option value="comic">Comic book</option>
              <option value="papercut">Paper cut</option>
              <option value="fantasy">Fantasy art</option>
              <option value="vintage">Vintage photo</option>
              <option value="pixel">Pixel art</option>
              <option value="claymation">Claymation</option>
              <option value="lineart">Line art</option>
              <option value="synthwave">Synthwave neon</option>
              <option value="folktale">African folktale</option>
            </select>
          </div>
          <button class="btn primary" id="buildStory" style="width:100%;justify-content:center;"><Icon name="sparkles" size={16} />Build story from script</button>
          <div id="storyProg" class="hint" style="margin-top:8px;text-align:center;display:none;">Building scene 1</div>
          <p class="hint" style="margin-top:8px;">Splits the script into scenes, illustrates each one, and loads the script into Narration. Then add a voiceover and press Auto fit.</p>
        </div>
      </div>

      <!-- AI scene generator -->
      <div class="card">
        <div class="card-head"><div><h3>AI scene generator</h3><p>Make scene images from prompts</p></div></div>
        <div class="card-body">
          <div class="field">
            <label>Scene prompts, one per line</label>
            <textarea class="textarea" id="scenePrompts" style="min-height:92px;" placeholder="A Roman man at a candlelit desk with a scroll, night
A field of valerian flowers at dawn
A close up of dried valerian root and a mortar"></textarea>
          </div>
          <div class="field" style="margin-bottom:12px;">
            <label>Art style</label>
            <select class="select" id="sceneStyle">
              <option value="folktale3d" selected>African folktale (3D animated)</option>
              <option value="watercolor">Watercolor illustration</option>
              <option value="cinematic">Cinematic photo</option>
              <option value="storybook">Storybook painting</option>
              <option value="anime">Anime</option>
              <option value="3d">3D render</option>
              <option value="flat">Flat vector</option>
              <option value="oil">Oil painting</option>
              <option value="pencil">Pencil sketch</option>
              <option value="comic">Comic book</option>
              <option value="papercut">Paper cut</option>
              <option value="fantasy">Fantasy art</option>
              <option value="vintage">Vintage photo</option>
              <option value="pixel">Pixel art</option>
              <option value="claymation">Claymation</option>
              <option value="lineart">Line art</option>
              <option value="synthwave">Synthwave neon</option>
              <option value="folktale">African folktale</option>
            </select>
          </div>
          <button class="btn primary" id="genScenes" style="width:100%;justify-content:center;"><Icon name="robot" size={16} />Generate scenes</button>
          <div id="sceneProg" class="hint" style="margin-top:8px;text-align:center;display:none;">Generating scene 1</div>
          <p class="hint" style="margin-top:8px;">Each line becomes an image on the timeline. Add a voiceover, then press Auto fit to sync them.</p>
        </div>
      </div>

      <!-- Selected clip -->
      <div class="card" id="clipPanel">
        <div class="card-head"><div><h3>Selected clip</h3><p id="clipHint">Pick a clip on the timeline</p></div></div>
        <div class="card-body">
          <div class="field">
            <label>Transition in</label>
            <select class="select" id="transSel" disabled>
              <option value="none">Hard cut</option>
              <option value="crossfade">Crossfade</option>
              <option value="fade">Fade through black</option>
              <option value="slide">Slide in</option>
              <option value="zoom">Zoom (Ken Burns)</option>
            </select>
          </div>
          <div class="field" id="durField">
            <label>Duration <span class="faint" id="durVal">3.0s</span></label>
            <input class="range" id="durRange" type="range" min="1" max="12" step="0.5" value="3" disabled />
          </div>
          <div id="trimField" style="display:none;">
            <div class="field">
              <label>Trim start <span class="faint" id="trimStartVal">0.0s</span></label>
              <input class="range" id="trimStart" type="range" min="0" max="10" step="0.1" value="0" />
            </div>
            <div class="field">
              <label>Trim end <span class="faint" id="trimEndVal">5.0s</span></label>
              <input class="range" id="trimEnd" type="range" min="0" max="10" step="0.1" value="5" />
            </div>
            <p class="hint" style="margin-top:0;">Clip length <span id="clipLen" style="color:var(--violet2);font-weight:700;">5.0s</span>. Drag the handles to keep only the part you want.</p>
          </div>
          <button class="btn sm" id="applyAll" disabled style="width:100%;justify-content:center;margin-top:6px;"><Icon name="swap" size={15} />Apply transition to all</button>
        </div>
      </div>

      <!-- Audio align -->
      <div class="card">
        <div class="card-head"><div><h3>Audio alignment</h3><p>Keep visuals in step</p></div></div>
        <div class="card-body">
          <div class="flex between center" style="margin-bottom:12px;">
            <div><div style="font-weight:600;font-size:13.5px;">Audio length</div><div class="faint" style="font-size:12px;" id="audioLen">No track loaded</div></div>
            <span class="badge draft" id="alignState"><span class="d"></span>Manual</span>
          </div>
          <button class="btn primary sm" id="autoFit" style="width:100%;justify-content:center;"><Icon name="target" size={15} />Auto fit clips to audio</button>
          <p class="hint" style="margin-top:10px;">This spreads your clips evenly across the audio so each visual lands with what is being said.</p>
        </div>
      </div>

      <!-- Voiceover recorder -->
      <div class="card">
        <div class="card-head"><div><h3>Voiceover recorder</h3><p>Record narration with your mic</p></div></div>
        <div class="card-body">
          <button class="btn" id="recBtn" style="width:100%;justify-content:center;"><Icon name="mic" size={16} />Start recording</button>
          <div id="recStatus" style="display:none;align-items:center;gap:10px;margin-top:14px;">
            <span class="rec-dot"></span>
            <span class="time" id="recTime" style="font-size:14px;">0:00</span>
            <span class="faint" style="font-size:12px;">Recording your voiceover</span>
          </div>
          <p class="hint" style="margin-top:10px;">Your recording becomes the voiceover track and can auto fit your clips.</p>
        </div>
      </div>

      <!-- Narration (keyless: natural neural voice or quick browser voice) -->
      <div class="card">
        <div class="card-head"><div><h3>Narration</h3><p>A natural voice, free and keyless</p></div></div>
        <div class="card-body">
          <div class="field"><label>Script</label><textarea class="textarea" id="ttsScript" style="min-height:80px;" placeholder="Paste your narration script here"></textarea></div>

          <label style="display:block;font-size:12.5px;font-weight:700;color:var(--muted);margin-bottom:8px;">Natural voice, runs on your device</label>
          <div class="field" style="margin-bottom:10px;">
            <select class="select" id="nvVoice">
              <option value="af_heart">Aria, warm US female</option>
              <option value="am_michael">Michael, calm US male</option>
              <option value="bm_george">George, UK documentary male</option>
              <option value="bf_emma">Emma, UK female</option>
              <option value="af_bella">Bella, US female</option>
              <option value="am_adam">Adam, US male</option>
            </select>
          </div>
          <button class="btn primary" id="nvGenerate" style="width:100%;justify-content:center;"><Icon name="sparkles" size={15} />Generate natural voiceover</button>

          <div style="border-top:1px solid var(--border); margin:14px 0 12px;"></div>

          <label style="display:block;font-size:12.5px;font-weight:700;color:var(--muted);margin-bottom:8px;">Quick browser voice</label>
          <div class="grid g-2" style="gap:10px;">
            <div class="field" style="margin-bottom:10px;"><select class="select" id="ttsVoice"></select></div>
            <div class="field" style="margin-bottom:10px;"><select class="select" id="ttsRate"><option value="0.9">Calm</option><option value="1" selected>Normal</option><option value="1.15">Lively</option></select></div>
          </div>
          <button class="btn" id="ttsPreview" style="width:100%;justify-content:center;"><Icon name="play" size={15} />Preview browser voice</button>

          <p class="hint" id="ttsHint" style="margin-top:10px;">The natural voice downloads once, then runs on your device with no key and bakes into the export. The browser voice is instant for checking timing.</p>
        </div>
      </div>

      <!-- Background music -->
      <div class="card">
        <div class="card-head"><div><h3>Background music</h3><p>Mix a track under your audio</p></div></div>
        <div class="card-body">
          <button class="btn" id="uploadMusic" style="width:100%;justify-content:center;"><Icon name="music" size={16} />Add music</button>
          <div id="musicControls" style="display:none;margin-top:14px;">
            <div class="flex between center" style="margin-bottom:10px;">
              <span style="font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;" id="musicName">track.mp3</span>
              <button class="btn sm ghost" id="removeMusic" style="color:var(--rose);">Remove</button>
            </div>
            <label style="font-size:12.5px;font-weight:700;color:var(--muted);">Music volume <span class="faint" id="musicVolVal">35%</span></label>
            <input class="range" id="musicVol" type="range" min="0" max="100" value="35" style="margin-top:6px;" />
          </div>
          <p class="hint" style="margin-top:10px;">Music loops under your voiceover and is mixed into the export.</p>
        </div>
      </div>

      <!-- On screen text -->
      <div class="card">
        <div class="card-head"><div><h3>On screen text</h3><p>Optional caption</p></div></div>
        <div class="card-body">
          <input class="input" id="capText" type="text" placeholder="For example, Chapter one" />
          <p class="hint" style="margin-top:8px;">Shows as a lower caption across the whole video.</p>
        </div>
      </div>

      <!-- Export -->
      <div class="card">
        <div class="card-head"><div><h3>Export</h3><p>Render to a video file</p></div></div>
        <div class="card-body">
          <label style="display:block;font-size:12.5px;font-weight:700;color:var(--muted);margin-bottom:8px;">Format</label>
          <div class="seg" id="formatSeg" style="margin-bottom:14px;">
            <button data-fmt="mp4" class="on">MP4</button>
            <button data-fmt="webm">WebM</button>
          </div>
          <div class="flex between" style="font-size:12.5px;margin-bottom:12px;">
            <span class="muted">Resolution</span><span style="font-weight:700;">1280 by 720</span>
          </div>
          <button class="btn primary" id="exportBtn" style="width:100%;justify-content:center;"><Icon name="download" size={16} />Export video</button>
          <div id="exportProg" style="display:none;margin-top:12px;">
            <div class="bar"><span id="exportFill" style="width:0%"></span></div>
            <p class="hint" style="margin-top:6px;text-align:center;" id="exportLabel">Recording your sequence</p>
          </div>
          <div id="renderHistory" style="margin-top:12px;"></div>
        </div>
      </div>
    </div>
  </section>

  <audio id="audioEl" style="display:none;"></audio>
  <audio id="musicEl" loop style="display:none;"></audio>
  <input type="file" id="imgInput" accept="image/*" multiple style="display:none;" />
  <input type="file" id="vidInput" accept="video/*" multiple style="display:none;" />
  <input type="file" id="audInput" accept="audio/*" style="display:none;" />
  <input type="file" id="musInput" accept="audio/*" style="display:none;" />

  <script is:inline>
  (function () {
    const canvas = document.getElementById("stage");
    const ctx = canvas.getContext("2d");
    const W = canvas.width, H = canvas.height;
    const TR = 0.6; // transition length in seconds

    const palettes = [
      ["#ff2d55", "#7c5cff"], ["#22d3ee", "#7c5cff"], ["#34d399", "#22d3ee"],
      ["#fbbf24", "#ff2d55"], ["#7c5cff", "#ff5e7d"], ["#22d3ee", "#34d399"]
    ];

    // Seed sample sequence so the studio works instantly
    let clips = [
      { emoji: "🎬", c: palettes[0], duration: 3, transition: "fade", img: null },
      { emoji: "🚀", c: palettes[1], duration: 3, transition: "crossfade", img: null },
      { emoji: "💡", c: palettes[2], duration: 3, transition: "slide", img: null },
      { emoji: "🎯", c: palettes[3], duration: 3, transition: "zoom", img: null }
    ];
    let selected = 0;
    let audio = null; // { duration }
    const audioEl = document.getElementById("audioEl");
    let caption = "";
    let exportFormat = "mp4";
    let isLive = false;      // true while previewing or exporting
    let activeVid = null;    // the video element currently on screen
    const musicEl = document.getElementById("musicEl");
    let music = null;        // { name } when a music track is loaded
    let musicVol = 0.35;

    // Keep the current video clip playing or seeked to the right spot
    function manageVideo(clip, lt) {
      if (clip.type === "video" && clip.el) {
        const v = clip.el;
        if (activeVid && activeVid !== v) activeVid.pause();
        activeVid = v;
        const off = clip.trimStart || 0;
        if (isLive) {
          if (v.paused) { try { v.currentTime = off + Math.min(lt, clip.duration); } catch (e) {} v.play().catch(() => {}); }
        } else {
          if (!v.paused) v.pause();
          try { v.currentTime = off + Math.min(lt, clip.duration); } catch (e) {}
        }
      } else if (activeVid) {
        activeVid.pause(); activeVid = null;
      }
    }

    const fmt = (s) => {
      s = Math.max(0, s);
      const m = Math.floor(s / 60);
      const ss = Math.floor(s % 60);
      return m + ":" + (ss < 10 ? "0" : "") + ss;
    };
    const totalDur = () => clips.reduce((a, c) => a + c.duration, 0);

    function coverDraw(media, mw, mh, scale, offsetX) {
      const ir = mw / mh, cr = W / H;
      let dw, dh;
      if (ir > cr) { dh = H * scale; dw = dh * ir; } else { dw = W * scale; dh = dw / ir; }
      ctx.drawImage(media, (W - dw) / 2 + offsetX, (H - dh) / 2, dw, dh);
    }

    function drawContent(clip, alpha, scale, offsetX) {
      ctx.save();
      ctx.globalAlpha = alpha;
      if (clip.type === "video" && clip.el && clip.el.readyState >= 2) {
        coverDraw(clip.el, clip.el.videoWidth || 1280, clip.el.videoHeight || 720, scale, offsetX);
      } else if (clip.img) {
        coverDraw(clip.img, clip.img.width, clip.img.height, scale, offsetX);
      } else {
        const g = ctx.createLinearGradient(0, 0, W, H);
        g.addColorStop(0, clip.c[0]); g.addColorStop(1, clip.c[1]);
        ctx.fillStyle = g;
        ctx.fillRect(offsetX, 0, W, H);
        ctx.globalAlpha = alpha * 0.9;
        ctx.font = (260 * scale) + "px serif";
        ctx.textAlign = "center"; ctx.textBaseline = "middle";
        ctx.fillText(clip.emoji, W / 2 + offsetX, H / 2);
      }
      ctx.restore();
    }

    function drawCaption() {
      if (!caption) return;
      ctx.save();
      ctx.textAlign = "center"; ctx.textBaseline = "middle";
      ctx.font = "700 52px Inter, sans-serif";
      const tw = ctx.measureText(caption).width;
      const bw = tw + 60, bh = 78, bx = (W - bw) / 2, by = H - 130;
      ctx.fillStyle = "rgba(10,11,18,.72)";
      ctx.beginPath();
      const r = 16;
      ctx.moveTo(bx + r, by); ctx.arcTo(bx + bw, by, bx + bw, by + bh, r);
      ctx.arcTo(bx + bw, by + bh, bx, by + bh, r); ctx.arcTo(bx, by + bh, bx, by, r);
      ctx.arcTo(bx, by, bx + bw, by, r); ctx.fill();
      ctx.fillStyle = "#ffffff";
      ctx.fillText(caption, W / 2, by + bh / 2 + 2);
      ctx.restore();
    }

    function draw(t) {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = "#05060a"; ctx.fillRect(0, 0, W, H);

      if (!clips.length) {
        ctx.fillStyle = "#6b7299"; ctx.font = "600 34px Inter, sans-serif";
        ctx.textAlign = "center"; ctx.textBaseline = "middle";
        ctx.fillText("Add clips to begin", W / 2, H / 2);
        return;
      }

      // find current clip
      let acc = 0, i = 0, lt = 0;
      for (i = 0; i < clips.length; i++) {
        if (t < acc + clips[i].duration || i === clips.length - 1) { lt = t - acc; break; }
        acc += clips[i].duration;
      }
      if (i >= clips.length) i = clips.length - 1;
      const clip = clips[i];
      lt = Math.max(0, Math.min(lt, clip.duration));
      manageVideo(clip, lt);
      const prev = clips[i - 1] || null;
      const eff = clip.transition;
      const inTrans = lt < TR && TR > 0;
      const p = Math.min(1, lt / TR);
      let scale = 1;
      if (eff === "zoom") scale = 1 + 0.1 * (lt / clip.duration);

      if (eff === "crossfade" && inTrans) {
        if (prev) drawContent(prev, 1, 1, 0); else { ctx.fillStyle = "#05060a"; ctx.fillRect(0, 0, W, H); }
        drawContent(clip, p, 1, 0);
      } else if (eff === "slide" && inTrans) {
        if (prev) drawContent(prev, 1, 1, 0);
        drawContent(clip, 1, 1, (1 - p) * W);
      } else if (eff === "fade" && inTrans) {
        drawContent(clip, 1, scale, 0);
        ctx.save(); ctx.globalAlpha = 1 - p; ctx.fillStyle = "#000"; ctx.fillRect(0, 0, W, H); ctx.restore();
      } else {
        drawContent(clip, 1, scale, 0);
      }
      drawCaption();
    }

    // ---------- timeline rendering ----------
    const track = document.getElementById("clipTrack");
    const addBtn = document.getElementById("addClipBtn");
    function renderTrack() {
      track.querySelectorAll(".clip").forEach((n) => n.remove());
      clips.forEach((c, idx) => {
        const el = document.createElement("div");
        el.className = "clip" + (idx === selected ? " sel" : "");
        el.setAttribute("data-i", idx);
        let bg;
        if (c.type === "video") bg = c.thumbUrl ? `<img src="${c.thumbUrl}" alt="">` : `<div class="big" style="background:linear-gradient(135deg,#222741,#1a1e30);width:100%;height:100%;">🎬</div>`;
        else if (c.img) bg = `<img src="${c.img.src}" alt="">`;
        else bg = `<div class="big" style="background:linear-gradient(135deg,${c.c[0]},${c.c[1]});width:100%;height:100%;">${c.emoji}</div>`;
        el.innerHTML =
          bg +
          `<span class="trans">${c.transition === "none" ? "cut" : c.transition}</span>` +
          `<span class="dur">${c.duration.toFixed(1)}s</span>` +
          `<button class="rm" data-rm="${idx}"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 5l14 14M19 5L5 19"/></svg></button>`;
        track.insertBefore(el, addBtn);
      });
      document.getElementById("totTime").textContent = fmt(totalDur());
      syncClipPanel();
    }

    function syncClipPanel() {
      const c = clips[selected];
      const ts = document.getElementById("transSel");
      const dr = document.getElementById("durRange");
      const aa = document.getElementById("applyAll");
      const durField = document.getElementById("durField");
      const trimField = document.getElementById("trimField");
      if (!c) {
        ts.disabled = dr.disabled = aa.disabled = true;
        durField.style.display = ""; trimField.style.display = "none";
        document.getElementById("clipHint").textContent = "Pick a clip on the timeline";
        return;
      }
      ts.disabled = aa.disabled = false;
      ts.value = c.transition;
      document.getElementById("clipHint").textContent = "Clip " + (selected + 1) + " of " + clips.length;

      if (c.type === "video") {
        // trimming controls for video clips
        durField.style.display = "none";
        trimField.style.display = "";
        const src = c.srcDur || c.duration;
        const ts0 = document.getElementById("trimStart");
        const te0 = document.getElementById("trimEnd");
        ts0.max = src.toFixed(1); te0.max = src.toFixed(1);
        ts0.value = (c.trimStart || 0);
        te0.value = (c.trimEnd != null ? c.trimEnd : c.duration);
        document.getElementById("trimStartVal").textContent = Number(ts0.value).toFixed(1) + "s";
        document.getElementById("trimEndVal").textContent = Number(te0.value).toFixed(1) + "s";
