    // ---------- AI scene generator ----------
    const styleKW = {
      watercolor: "storybook illustration, clean bold ink outlines, flat soft watercolor fills, warm vivid palette, gentle cel shading, cream paper background with loose watercolor edges, editorial childrens book art, crisp and detailed, not photorealistic",
      cinematic: "cinematic photograph, dramatic lighting, film still, highly detailed, 35mm",
      storybook: "storybook painting, warm, painterly, whimsical",
      anime: "anime style, cel shaded, vibrant, detailed background",
      "3d": "3d render, soft studio lighting, subsurface scattering, pixar style",
      flat: "flat vector illustration, minimal, bold shapes, clean",
      oil: "oil painting, rich impasto brushstrokes, classical, textured canvas, warm light",
      pencil: "detailed pencil sketch, graphite shading, cross hatching, monochrome, hand drawn",
      comic: "comic book illustration, bold ink outlines, halftone dots, dynamic, vibrant colors",
      papercut: "layered paper cut art, soft drop shadows, tactile, handcrafted, clean edges",
      fantasy: "epic fantasy concept art, luminous atmosphere, highly detailed digital painting",
      vintage: "vintage photograph, faded film grain, nostalgic, sepia and muted tones",
      pixel: "pixel art, 16 bit retro game style, crisp pixels, limited palette",
      claymation: "claymation, plasticine clay model, stop motion, soft studio light",
      lineart: "elegant line art, minimal single weight lines, clean white background",
      synthwave: "synthwave retro futuristic, neon glow, purple and cyan, 1980s aesthetic",
      folktale: "African folktale illustration, rich earth tones, bold tribal patterns, Ndebele and Kente inspired motifs, warm ochre and indigo palette, textured, storytelling art",
      folktale3d: "3D animated feature film still in the style of a Pixar and DreamWorks African folktale, expressive stylized characters with warm dark skin and soft subsurface shading, bright warm natural daylight with soft even front lighting so the characters are clearly and fully lit and easy to see, no dark silhouettes and no heavy backlighting, vibrant and colourful, rural West African village of thatched-roof huts, acacia trees and gentle green hills under a bright blue sky, richly textured woven robes and carved wood, gentle global illumination, high detail, wholesome and heartwarming, not photorealistic, balanced natural framing, mostly wide and medium establishing shots that show the full figure and the surroundings with generous headroom, the main character well lit and clearly visible, not a tightly cropped close-up"
    };
    function loadSceneImage(prompt, style, seed) {
      return new Promise((resolve) => {
        const full = prompt + ", " + (styleKW[style] || "");
        const url = "/ai-image/" + encodeURIComponent(full) + "?width=1280&height=720&nologo=true&model=flux&seed=" + seed;
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = () => resolve(null);
        img.src = url;
      });
    }
    // Retry a few times so an occasional image hiccup does not drop a scene
    async function generateScene(prompt, style, seed) {
      let img = null;
      for (let attempt = 0; attempt < 3 && !img; attempt++) {
        img = await loadSceneImage(prompt, style, seed + attempt * 1000);
        if (!img && attempt < 2) await new Promise((r) => setTimeout(r, 1500));
      }
      if (!img) return false;
      clips.push({ img: img, c: palettes[clips.length % palettes.length], duration: 4, transition: "crossfade", emoji: "🖼️" });
      return true;
    }
    document.getElementById("genScenes").addEventListener("click", async () => {
      const lines = (document.getElementById("scenePrompts").value || "").split("\n").map((s) => s.trim()).filter(Boolean);
      if (!lines.length) { window.showToast("Add at least one scene prompt"); return; }
      const style = document.getElementById("sceneStyle").value;
      const btn = document.getElementById("genScenes");
      const prog = document.getElementById("sceneProg");
      btn.disabled = true; prog.style.display = "block";
      const baseSeed = 1000 + lines.length;
      let ok = 0;
      for (let i = 0; i < lines.length; i++) {
        prog.textContent = "Generating scene " + (i + 1) + " of " + lines.length;
        const success = await generateScene(lines[i], style, baseSeed + i * 7);
        if (success) { ok++; selected = clips.length - 1; renderTrack(); draw(0); setPlayhead(0); }
      }
      btn.disabled = false; prog.style.display = "none";
      window.showToast(ok ? (ok + " scene(s) added to the timeline") : "The image model was unreachable");
    });

    // ---------- story builder (script splitter) ----------
    function splitScript(text) {
      text = text.trim().replace(/[ \t]+/g, " ").replace(/\n+/g, " ");
      let sentences = text.match(/[^.!?]+[.!?]+/g);
      if (!sentences || sentences.length < 2) sentences = text.split(/(?<=[.!?])\s+|\n+/);
      sentences = sentences.map((s) => s.trim()).filter(Boolean);
      const TARGET = 30; // words per scene
      const parts = [];
      let cur = "", words = 0;
      for (const s of sentences) {
        const w = s.split(/\s+/).filter(Boolean).length;
        cur = cur ? cur + " " + s : s;
        words += w;
        if (words >= TARGET) { parts.push(cur); cur = ""; words = 0; }
      }
      if (cur) parts.push(cur);
      return parts.length ? parts.slice(0, 500) : [text];
    }

    document.getElementById("buildStory").addEventListener("click", async () => {
      const text = (document.getElementById("storyScript").value || "").trim();
      if (!text) { window.showToast("Paste a script first"); return; }
      const scenes = splitScript(text);
      const style = document.getElementById("storyStyle").value;
      const btn = document.getElementById("buildStory");
      const prog = document.getElementById("storyProg");

      // load the full script into the narration box for the voiceover
      document.getElementById("ttsScript").value = text;
      // start a clean story: drop the sample placeholder clips, keep any real media
      clips = clips.filter((c) => c.img || c.type === "video");

      btn.disabled = true; prog.style.display = "block";
      const transitions = ["zoom", "crossfade"];
      let ok = 0;
      for (let i = 0; i < scenes.length; i++) {
        prog.textContent = "Building scene " + (i + 1) + " of " + scenes.length;
        const success = await generateScene(scenes[i], style, 2000 + i * 7);
        if (success) {
          ok++;
          const clip = clips[clips.length - 1];
          clip.transition = transitions[i % 2];
          clip.duration = 4;
          selected = clips.length - 1; renderTrack(); draw(0); setPlayhead(0);
        }
      }
      btn.disabled = false; prog.style.display = "none";
      window.showToast(ok ? (ok + " scenes built. Add narration, then press Auto fit.") : "The image model was unreachable");
    });

