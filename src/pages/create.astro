    // ---------- playback ----------
    let playing = false, rafId = null, startStamp = 0, seekOffset = 0, curT = 0;
    const playBtn = document.getElementById("playBtn");
    const scrubFill = document.getElementById("scrubFill");

    function setPlayhead(t) {
      curT = t;
      const total = totalDur() || 1;
      scrubFill.style.width = Math.min(100, (t / total) * 100) + "%";
      document.getElementById("curTime").textContent = fmt(t);
    }

    function loop(now) {
      const t = seekOffset + (now - startStamp) / 1000;
      const total = totalDur();
      if (t >= total) { draw(total); setPlayhead(total); stop(); return; }
      draw(t); setPlayhead(t);
      rafId = requestAnimationFrame(loop);
    }

    function play() {
      if (!clips.length) return;
      if (curT >= totalDur()) { seekOffset = 0; } else { seekOffset = curT; }
      playing = true; isLive = true;
      playBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M8 5v14M16 5v14"/></svg>';
      if (audio) { try { audioEl.currentTime = seekOffset; audioEl.play(); } catch (e) {} }
      if (music) { try { musicEl.volume = musicVol; musicEl.play(); } catch (e) {} }
      startStamp = performance.now();
      rafId = requestAnimationFrame(loop);
    }
    function stop() {
      playing = false; isLive = false;
      cancelAnimationFrame(rafId);
      playBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M6 4l14 8-14 8z"/></svg>';
      if (audio) audioEl.pause();
      if (music) musicEl.pause();
      if (activeVid) activeVid.pause();
    }
    playBtn.addEventListener("click", () => { playing ? stop() : play(); });

    document.getElementById("scrub").addEventListener("click", (e) => {
      const rect = e.currentTarget.getBoundingClientRect();
      const frac = (e.clientX - rect.left) / rect.width;
      const t = frac * totalDur();
      stop(); setPlayhead(t); draw(t);
    });

    // ---------- export (real recording) ----------
    let audioGraph = null, voiceSrc = null, musicSrc = null, musicGain = null;
    function ensureAudioGraph() {
      if (!audio && !music) return null;
      if (!audioGraph) {
        const ac = new (window.AudioContext || window.webkitAudioContext)();
        const dest = ac.createMediaStreamDestination();
        audioGraph = { ac, dest };
      }
      const ac = audioGraph.ac, dest = audioGraph.dest;
      if (audio && !voiceSrc) {
        voiceSrc = ac.createMediaElementSource(audioEl);
        voiceSrc.connect(dest); voiceSrc.connect(ac.destination);
      }
      if (music && !musicSrc) {
        musicSrc = ac.createMediaElementSource(musicEl);
        musicGain = ac.createGain(); musicGain.gain.value = musicVol;
        musicSrc.connect(musicGain); musicGain.connect(dest); musicGain.connect(ac.destination);
      }
      return audioGraph;
    }

    document.getElementById("exportBtn").addEventListener("click", async () => {
      if (!clips.length) { window.showToast("Add a clip first"); return; }
      stop();
      const total = totalDur();
      const prog = document.getElementById("exportProg");
      const fill = document.getElementById("exportFill");
      const label = document.getElementById("exportLabel");
      const btn = document.getElementById("exportBtn");
      prog.style.display = "block"; btn.disabled = true; label.textContent = "Recording your sequence";

      const fps = 30;
      const vStream = canvas.captureStream(fps);
      let tracks = vStream.getVideoTracks();
      if (audio || music) {
        const g = ensureAudioGraph();
        if (g) {
          if (g.ac.state === "suspended") await g.ac.resume();
          tracks = tracks.concat(g.dest.stream.getAudioTracks());
        }
      }
      const mixed = new MediaStream(tracks);

      let mime = "", ext = "webm";
      if (exportFormat === "mp4") {
        const mp4a = "video/mp4;codecs=avc1.42E01E,mp4a.40.2";
        if (MediaRecorder.isTypeSupported(mp4a)) { mime = mp4a; ext = "mp4"; }
        else if (MediaRecorder.isTypeSupported("video/mp4")) { mime = "video/mp4"; ext = "mp4"; }
      }
      if (!mime) {
        if (MediaRecorder.isTypeSupported("video/webm;codecs=vp9,opus")) mime = "video/webm;codecs=vp9,opus";
        else if (MediaRecorder.isTypeSupported("video/webm;codecs=vp8,opus")) mime = "video/webm;codecs=vp8,opus";
        else mime = "video/webm";
        ext = "webm";
        if (exportFormat === "mp4") window.showToast("MP4 is not supported in this browser, saving WebM");
      }
      const rec = new MediaRecorder(mixed, { mimeType: mime, videoBitsPerSecond: 6000000 });
      const chunks = [];
      rec.ondataavailable = (e) => { if (e.data.size) chunks.push(e.data); };
      rec.onstop = () => {
        const blob = new Blob(chunks, { type: ext === "mp4" ? "video/mp4" : "video/webm" });
        const url = URL.createObjectURL(blob);
        addRender(url, blob.size, ext);
        prog.style.display = "none"; btn.disabled = false;
        window.showToast(ext.toUpperCase() + " video ready to download");
      };

      // drive playback in real time while recording
      rec.start();
      seekOffset = 0; curT = 0; isLive = true;
      if (audio) { try { audioEl.currentTime = 0; audioEl.play(); } catch (e) {} }
      if (music) { try { musicEl.currentTime = 0; musicEl.volume = musicVol; musicEl.play(); } catch (e) {} }
      const begin = performance.now();
      let finished = false;
      function finish() {
        if (finished) return;
        finished = true;
        clearInterval(drv);
        isLive = false;
        draw(total);
        if (audio) audioEl.pause();
        if (music) musicEl.pause();
        if (activeVid) activeVid.pause();
        if (rec.state !== "inactive") rec.stop();
      }
      // a timer driver keeps advancing even when animation frames are throttled
      const drv = setInterval(function () {
        const t = (performance.now() - begin) / 1000;
        if (t >= total) { finish(); return; }
        draw(t); setPlayhead(t);
        fill.style.width = Math.min(100, (t / total) * 100) + "%";
      }, 1000 / fps);
      // guaranteed stop so a file is always produced
      setTimeout(finish, total * 1000 + 600);
    });

    let renderCount = 0;
    function humanSize(b) {
      if (b < 1024) return b + " B";
      if (b < 1048576) return (b / 1024).toFixed(0) + " KB";
      return (b / 1048576).toFixed(1) + " MB";
    }
    function addRender(url, size, ext) {
      renderCount++;
      ext = ext || "webm";
      const box = document.getElementById("renderHistory");
      const row = document.createElement("div");
      row.className = "render-row";
      row.innerHTML =
        `<div class="ico green" style="width:34px;height:34px;border-radius:9px;flex-shrink:0;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4" width="19" height="16" rx="2.5"/><path d="M10 9l6 3-6 3z"/></svg></div>` +
        `<div style="flex:1;min-width:0;"><div style="font-weight:600;font-size:13px;">export_${renderCount}.${ext}</div><div class="faint" style="font-size:11.5px;">${humanSize(size)} · 1280 by 720</div></div>` +
        `<a class="btn sm primary" href="${url}" download="creatorflow_export_${renderCount}.${ext}">Save</a>`;
      box.insertBefore(row, box.firstChild);
    }

    // init
    renderTrack();
    setPlayhead(0);
    draw(0);
  })();
  </script>
</Layout>
