    document.getElementById("uploadAudio").addEventListener("click", () => audInput.click());
    document.getElementById("uploadMusic").addEventListener("click", () => musInput.click());

    // add one or many video clips
    function addVideoClip(file, k) {
      const v = document.createElement("video");
      v.src = URL.createObjectURL(file);
      v.muted = true; v.playsInline = true; v.preload = "auto";
      v.addEventListener("loadeddata", () => {
        const srcDur = (isFinite(v.duration) && v.duration > 0.2) ? v.duration : 8;
        const end = Math.min(srcDur, 12);
        const clip = { type: "video", el: v, srcDur: srcDur, trimStart: 0, trimEnd: Math.round(end * 10) / 10, duration: Math.round(end * 10) / 10, transition: "crossfade", thumbUrl: null, name: file.name };
        clips.push(clip);
        selected = clips.length - 1;
        renderTrack(); draw(0); setPlayhead(0);
        // capture a poster frame for the timeline
        const onSeek = () => {
          try {
            const cnv = document.createElement("canvas"); cnv.width = 216; cnv.height = 120;
            cnv.getContext("2d").drawImage(v, 0, 0, 216, 120);
            clip.thumbUrl = cnv.toDataURL("image/jpeg", 0.7);
            renderTrack();
          } catch (e) {}
          v.removeEventListener("seeked", onSeek);
        };
        v.addEventListener("seeked", onSeek);
        try { v.currentTime = Math.min(0.1, srcDur); } catch (e) {}
      }, { once: true });
    }

