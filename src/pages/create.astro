    // start time of a clip on the timeline
    function clipStart(idx) {
      let s = 0;
      for (let i = 0; i < idx; i++) s += clips[i].duration;
      return s;
    }

    track.addEventListener("click", (e) => {
      const rm = e.target.closest("[data-rm]");
      if (rm) {
        const idx = parseInt(rm.getAttribute("data-rm"), 10);
        clips.splice(idx, 1);
        if (selected >= clips.length) selected = clips.length - 1;
        renderTrack(); draw(0); setPlayhead(0);
        return;
      }
      const clip = e.target.closest(".clip");
      if (clip) { selected = parseInt(clip.getAttribute("data-i"), 10); renderTrack(); }
    });

    document.getElementById("transSel").addEventListener("change", (e) => {
