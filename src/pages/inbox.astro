---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { comments } from "../data/demo.js";

const unanswered = comments.filter((c) => !c.answered).length;
const questions = comments.filter((c) => c.sentiment === "question").length;
const flagged = comments.filter((c) => c.sentiment === "negative").length;

const kpis = [
  { label: "Needs a reply", value: unanswered, icon: "inbox", color: "violet" },
  { label: "Questions", value: questions, icon: "comment", color: "cyan" },
  { label: "Flagged", value: flagged, icon: "flag", color: "red" },
  { label: "Replied today", value: 0, icon: "check", color: "green" }
];
---
<Layout title="Comment Inbox" subtitle="Reply faster and keep your community close" active="inbox" page="Comment Inbox">

  <section class="grid g-4" style="margin-bottom:20px;">
    {kpis.map((k) => (
      <div class="card pad">
        <div class="flex center gap-10" style="margin-bottom:10px;">
          <div class={`ico ${k.color}`} style="width:38px;height:38px;border-radius:11px;"><Icon name={k.icon} size={18} /></div>
          <div class="label muted" style="font-size:12.5px;font-weight:600;">{k.label}</div>
        </div>
        <div class="big-num">{k.value}</div>
      </div>
    ))}
  </section>

  <div class="section-head">
    <div><h2>Conversations</h2><p>Answer, react, and moderate in one place</p></div>
    <div class="actions">
      <div class="chips" id="inboxFilter">
        <button class="chip active" data-f="all">All</button>
        <button class="chip" data-f="unanswered">Unanswered</button>
        <button class="chip" data-f="question">Questions</button>
        <button class="chip" data-f="negative">Flagged</button>
      </div>
    </div>
  </div>

  <div id="inboxList">
    {comments.map((c, i) => (
      <div class="inbox-row" data-answered={c.answered ? "1" : "0"} data-sentiment={c.sentiment} data-i={i}>
        <div class="inbox-av" style={`background:${c.color}`}>{c.av}</div>
        <div class="inbox-body">
          <div class="inbox-head">
            <span class="who">{c.who}</span>
            <span class={`sent ${c.sentiment}`}>{c.sentiment}</span>
            <span class="on">on {c.on}</span>
            <span class="on">· {c.time}</span>
          </div>
          <div class="inbox-text">{c.text}</div>
          <div class="inbox-actions">
            <button class="btn sm primary" data-act="reply"><Icon name="comment" size={14} />Reply</button>
            <button class="btn sm" data-act="like"><Icon name="heart" size={14} />Like <span class="faint">{c.likes}</span></button>
            <button class="btn sm" data-act="done"><Icon name="check" size={14} />{c.answered ? "Answered" : "Mark done"}</button>
            <button class="btn sm ghost" data-act="flag"><Icon name="flag" size={14} /></button>
          </div>
          <div class="reply-box">
            <input class="input" placeholder="Write a friendly reply" />
            <button class="btn primary" data-act="send">Send</button>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div class="empty-note" id="inboxEmpty" style={comments.length ? "display:none;" : "display:block;"}>No comments yet. When your published videos get comments, they show up here.</div>

  <script is:inline>
    const list = document.getElementById("inboxList");

    list.addEventListener("click", (e) => {
      const row = e.target.closest(".inbox-row");
      if (!row) return;
      const btn = e.target.closest("[data-act]");
      if (!btn) return;
      const act = btn.getAttribute("data-act");

      if (act === "reply") {
        row.querySelector(".reply-box").classList.toggle("open");
      } else if (act === "send") {
        row.querySelector(".reply-box").classList.remove("open");
        row.setAttribute("data-answered", "1");
        row.classList.add("done");
        window.showToast("Reply sent");
        applyFilter(document.querySelector("#inboxFilter .chip.active").getAttribute("data-f"));
      } else if (act === "done") {
        const now = row.getAttribute("data-answered") === "1" ? "0" : "1";
        row.setAttribute("data-answered", now);
        row.classList.toggle("done", now === "1");
        btn.innerHTML = now === "1"
          ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Answered'
          : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Mark done';
      } else if (act === "like") {
        btn.style.color = "var(--rose)";
        window.showToast("Comment liked");
      } else if (act === "flag") {
        row.setAttribute("data-sentiment", "negative");
        window.showToast("Comment flagged for review");
      }
    });

    function applyFilter(f) {
      let shown = 0;
      list.querySelectorAll(".inbox-row").forEach((row) => {
        let match = true;
        if (f === "unanswered") match = row.getAttribute("data-answered") === "0";
        else if (f === "question") match = row.getAttribute("data-sentiment") === "question";
        else if (f === "negative") match = row.getAttribute("data-sentiment") === "negative";
        row.style.display = match ? "" : "none";
        if (match) shown++;
      });
      document.getElementById("inboxEmpty").style.display = shown ? "none" : "block";
    }
    document.getElementById("inboxFilter").addEventListener("click", (e) => {
      const chip = e.target.closest(".chip");
      if (!chip) return;
      document.querySelectorAll("#inboxFilter .chip").forEach((c) => c.classList.remove("active"));
      chip.classList.add("active");
      applyFilter(chip.getAttribute("data-f"));
    });
  </script>
</Layout>
